{
  "name": "disastream-front",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/disastream-front/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/disastream-front",
        "index": "apps/disastream-front/src/index.html",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/disastream-front/tsconfig.app.json",
        "assets": [
          "apps/disastream-front/src/robots.txt",
          "apps/disastream-front/src/favicon.ico",
          {
            "glob": "**/*",
            "input": "apps/disastream-front/src/assets",
            "output": "assets"
          }
        ],
        "styles": [
          "apps/disastream-front/src/styles.css"
        ],
        "allowedCommonJsDependencies": [
          "leaflet"
        ]
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/disastream-front/src/environments/environment.ts",
              "with": "apps/disastream-front/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "4mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "development"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "disastream-front:build:production"
        },
        "development": {
          "buildTarget": "disastream-front:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "lintFilePatterns": [
          "src/**/*.ts",
          "src/**/*.html"
        ]
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "disastream-front:build",
        "port": 4200,
        "staticFilePath": "dist/apps/disastream-front/browser",
        "spa": true
      }
    }
  },
  "cli": {
    "analytics": "0565266c-cfab-4455-8bcd-f7b004322cb6"
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}